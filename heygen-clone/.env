# Flask Configuration
SECRET_KEY='your_super_secret_key_for_flask_session_security'
JWT_SECRET_KEY='your_jwt_secret_key_for_token_signing_security'
JWT_ACCESS_TOKEN_EXPIRES=900
JWT_REFRESH_TOKEN_EXPIRES=2592000
JWT_IDENTITY_CLAIM='sub'

# Database Configuration (for MySQL)
DB_USERNAME='heygen_user'
DB_PASSWORD='your_secure_database_password'
DB_HOST='localhost'
DB_PORT='3306'
DB_NAME='heygen_clone_db'

# Redis Configuration
REDIS_URL='redis://localhost:6379/0'
RATELIMIT_STORAGE_URL='redis://localhost:6379/1'

# OpenAI API Key
OPENAI_API_KEY='sk-your_openai_api_key_here'

# ElevenLabs API Key (Optional)
ELEVENLABS_API_KEY='your_elevenlabs_api_key_here'

# Stripe API Configuration
STRIPE_SECRET_KEY='sk_test_your_stripe_secret_key'
STRIPE_WEBHOOK_SECRET='whsec_your_webhook_secret'
STRIPE_PRO_PRICE_ID='price_your_pro_plan_price_id'

# AWS S3 Configuration
AWS_ACCESS_KEY_ID='your_aws_access_key_id'
AWS_SECRET_ACCESS_KEY='your_aws_secret_access_key'
AWS_REGION='us-east-1'
AWS_S3_BUCKET_NAME='your_s3_bucket_name'

# Email Configuration
SENDGRID_API_KEY='your_sendgrid_api_key'
FROM_EMAIL='noreply@yourdomain.com'
